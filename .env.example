# GoHighLevel CRM — Contact form integration
# Get your API token from GoHighLevel: Settings → API Keys → Private Integration (contacts.write).
# Location ID is optional: if omitted, the server uses the first location returned by the API.
GHL_API_TOKEN=
# Optional. Leave empty to auto-detect from your token.
# GHL_LOCATION_ID=

# Optional: Custom field IDs in GHL for "Message" and "I'm Interested In"
# Create custom contact fields in GHL, then paste their IDs here to store message/interest on the contact.
# GHL_MESSAGE_FIELD_ID=
# GHL_INTEREST_FIELD_ID=
